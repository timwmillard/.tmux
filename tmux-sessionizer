#!/usr/bin/env bash

# https://github.com/ThePrimeagen/.dotfiles/blob/master/bin/.local/scripts/tmux-sessionizer

if [[ $# -eq 1 ]]; then
    selected=$1
else
    selected=$(find \
        ~/cprogs \
        ~/cprogs/vendor \
        ~/rapid \
        ~/rapid/*/.worktrees \
        ~/feewise \
        ~/feewise/*/.worktrees \
        ~/dev \
        ~/dev/*/.worktrees \
        ~/dev/vendor \
        ~/go/src \
        ~/.config \
        -mindepth 1 -maxdepth 1 -type d | fzf)
fi

if [[ -z $selected ]]; then
    exit 0
fi

selected=$(cd "$selected" && pwd -P) || exit 1
selected_name=$(basename "$selected" | tr . _)
tmux_running=$(pgrep tmux)

find_existing_session() {
    local selected_path=$1
    local session_name
    local pane_current_path
    local normalized_pane_path

    while IFS=$'\t' read -r session_name pane_current_path; do
        [[ -z $session_name || -z $pane_current_path || ! -d $pane_current_path ]] && continue

        normalized_pane_path=$(cd "$pane_current_path" && pwd -P)
        if [[ $normalized_pane_path == "$selected_path" ]]; then
            printf '%s\n' "$session_name"
            return 0
        fi
    done < <(tmux list-panes -a -F "#{session_name}	#{pane_current_path}" 2> /dev/null)

    return 1
}

if [[ -z $TMUX ]] && [[ -z $tmux_running ]]; then
    tmux new-session -s "$selected_name" -c "$selected"
    exit 0
fi

existing_session=$(find_existing_session "$selected")
if [[ -n $existing_session ]]; then
    selected_name=$existing_session
fi

if ! tmux has-session -t "=$selected_name" 2> /dev/null; then
    tmux new-session -ds "$selected_name" -c "$selected"
fi

tmux switch-client -t "=$selected_name"
