#!/usr/bin/env bash

# https://github.com/ThePrimeagen/.dotfiles/blob/master/bin/.local/scripts/tmux-sessionizer

if [[ $# -eq 1 ]]; then
    selected=$1
else
    selected=$(find \
        ~/cprogs \
        ~/cprogs/vendor \
        ~/rapid \
        ~/rapid/*/.worktrees \
        ~/feewise \
        ~/feewise/*/.worktrees \
        ~/dev \
        ~/dev/*/.worktrees \
        ~/dev/vendor \
        ~/go/src \
        ~/.config \
        -mindepth 1 -maxdepth 1 -type d | fzf)
fi

if [[ -z $selected ]]; then
    exit 0
fi

selected=$(cd "$selected" && pwd -P) || exit 1
selected_name=$(basename "$selected" | tr . _)
tmux_running=$(pgrep tmux)

find_existing_session() {
    local selected_path=$1
    local base_name=$2
    local project_name=
    local session_name
    local session_path
    local normalized_session_path
    local exact_match=
    local project_match=
    local suffix_match=
    local suffix_count=0
    local path_match=
    local path_count=0
    local exact_path_match=
    local project_path_match=
    local suffix_path_match=
    local suffix_path_count=0

    if [[ $selected_path == */.worktrees/* ]]; then
        project_name=$(basename "$(dirname "$(dirname "$selected_path")")" | tr . _)
    fi

    while IFS=$'\t' read -r session_name session_path; do
        [[ -z $session_name ]] && continue

        if [[ -n $session_path && -d $session_path ]]; then
            normalized_session_path=$(cd "$session_path" && pwd -P)
            if [[ $normalized_session_path == "$selected_path" ]]; then
                path_match=$session_name
                ((path_count++))

                if [[ $session_name == "$base_name" ]]; then
                    exact_path_match=$session_name
                fi

                if [[ -n $project_name && $session_name == *" $project_name $base_name" ]]; then
                    project_path_match=$session_name
                fi

                if [[ $session_name == *" $base_name" ]]; then
                    suffix_path_match=$session_name
                    ((suffix_path_count++))
                fi
            fi
        fi

        if [[ $session_name == "$base_name" ]]; then
            exact_match=$session_name
        fi

        if [[ -n $project_name && $session_name == *" $project_name $base_name" ]]; then
            project_match=$session_name
        fi

        if [[ $session_name == *" $base_name" ]]; then
            suffix_match=$session_name
            ((suffix_count++))
        fi
    done < <(tmux list-sessions -F "#{session_name}	#{session_path}" 2> /dev/null)

    if [[ -n $exact_path_match ]]; then
        printf '%s\n' "$exact_path_match"
        return 0
    fi

    if [[ -n $project_path_match ]]; then
        printf '%s\n' "$project_path_match"
        return 0
    fi

    if [[ $suffix_path_count -eq 1 ]]; then
        printf '%s\n' "$suffix_path_match"
        return 0
    fi

    if [[ $path_count -eq 1 ]]; then
        printf '%s\n' "$path_match"
        return 0
    fi

    if [[ -n $exact_match ]]; then
        printf '%s\n' "$exact_match"
        return 0
    fi

    if [[ -n $project_match ]]; then
        printf '%s\n' "$project_match"
        return 0
    fi

    if [[ $suffix_count -eq 1 ]]; then
        printf '%s\n' "$suffix_match"
        return 0
    fi

    return 1
}

if [[ -z $TMUX ]] && [[ -z $tmux_running ]]; then
    tmux new-session -s "$selected_name" -c "$selected"
    exit 0
fi

existing_session=$(find_existing_session "$selected" "$selected_name")
if [[ -n $existing_session ]]; then
    selected_name=$existing_session
fi

if ! tmux has-session -t "=$selected_name" 2> /dev/null; then
    tmux new-session -ds "$selected_name" -c "$selected"
fi

tmux switch-client -t "=$selected_name"
